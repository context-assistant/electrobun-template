{
  "name": "bun-react-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bun scripts/patch-electrobun-url-join.ts",
    "dev": "bun run dev:app",
    "dev:server": "bun --hot src/dev-server.ts",
    "dev:app": "bunx electrobun build --env=dev && bun scripts/open-electrobun-app.ts --env=dev",
    "build": "bun run build:app",
    "build:app": "bunx electrobun build --env=stable",
    "build:landing": "bun scripts/build-landing.ts",
    "prepreview:landing": "bun run build:landing",
    "preview:landing": "bun x serve landing",
    "generate:icons": "bun scripts/generate-app-icons.ts",
    "prettier": "prettier --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/merge": "^6.11.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.13",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@replit/codemirror-minimap": "^0.5.2",
    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/codemirror-themes": "^4.25.4",
    "@uiw/codemirror-themes-all": "^4.25.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "codemirror-copilot": "^0.0.7",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electrobun": "0.8.0",
    "happy-dom": "^18.0.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
